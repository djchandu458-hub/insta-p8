# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Instagram / Meta App
# Get these from https://developers.facebook.com/apps/ -> Your App -> Instagram -> Basic Display / Instagram Login
# NOTE: The app must have "Instagram Login with Facebook" enabled (not "Instagram Basic Display")
# Both NEXT_PUBLIC_INSTAGRAM_APP_ID and INSTAGRAM_APP_ID must be the same value (your Meta App ID).
NEXT_PUBLIC_INSTAGRAM_APP_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Must exactly match the "Valid OAuth Redirect URIs" in your Meta App settings:
#   Meta Dev Console -> Your App -> Instagram -> Instagram Login with Facebook -> "Valid OAuth Redirect URIs"
NEXT_PUBLIC_INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/callback
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# AI Gateway / Auto Reply
GATEWAY_SECRET=

# Internal API Hooks
API_SECRET_KEY=
