# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Instagram / Meta App
# Get these from https://developers.facebook.com/apps/ -> Your App -> Instagram -> Basic Display / Instagram Login
# NOTE: The app must have "Instagram Login with Facebook" enabled (not "Instagram Basic Display")
# Both NEXT_PUBLIC_INSTAGRAM_APP_ID and INSTAGRAM_APP_ID must be the same value (your Meta App ID).
NEXT_PUBLIC_INSTAGRAM_APP_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Must exactly match the "Valid OAuth Redirect URIs" in your Meta App settings:
#   Meta Dev Console -> Your App -> Instagram -> Instagram Login with Facebook -> "Valid OAuth Redirect URIs"
NEXT_PUBLIC_INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/callback
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# AI Gateway / Auto Reply
GATEWAY_SECRET=

# Internal API Hooks (used by direct-post, publish-reel, upload-washed-reel)
API_SECRET_KEY=

# CRON Secret (optional but recommended — protects /api/scheduler from unauthorized access)
# Set this and pass it as Authorization: Bearer <value> when calling /api/scheduler
CRON_SECRET=

# Supabase Auth (for email/password + magic link)
# Enable email/password auth in your Supabase dashboard:
#   Authentication -> Providers -> Email -> Enable signups
# The auth callback URL must be added to your Supabase project:
#   Authentication -> URL Configuration -> Redirect URLs
#   Add: http://localhost:3000/auth/callback (and your production URL)
